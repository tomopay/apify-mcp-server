{
    "mcpServers": {
        "storybook": {
            "type": "http",
            "url": "https://baldasseva--storybook-mcp.apify.actor/mcp?token=${APIFY_TOKEN}"
        },
        "figma": {
            "type": "http",
            "url": "https://mcp.figma.com/mcp"
        },
        "dev": {
            "url": "http://localhost:3001",
            "headers": {
                "Authorization": "Bearer ${APIFY_TOKEN}"
            }
        },
        "stdio": {
            "command": "node",
            "args": ["dist/stdio.js"],
            "env": {
                "APIFY_TOKEN": "${APIFY_TOKEN}"
            }
        }
    }
}
